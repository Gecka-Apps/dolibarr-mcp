# Dolibarr Configuration
DOLIBARR_URL=https://your-dolibarr.example.com/api/index.php
DOLIBARR_API_KEY=YOUR_API_KEY_HERE

# Logging
LOG_LEVEL=INFO

# MCP HTTP listener (recommended for Docker Compose)
MCP_TRANSPORT=http
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080
MCP_HOST_PORT=18004

# Optional URL token — first path segment must match this value, else 404.
# Useful when the reverse proxy cannot do Basic Auth (e.g. Claude Desktop).
# Generate with: openssl rand -hex 32
# MCP_URL_TOKEN=

# Response shaping
# MAX_RESPONSE_CHARS=100000
# DEFAULT_LIST_LIMIT=20

# Database connection (optional, enables analytics tools)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=dolibarr
# DB_USER=dolibarr
# DB_PASSWORD=secret
# DB_PREFIX=llx_

# Docker Compose naming
MCP_CONTAINER_NAME=dolibarr-mcp-server
MCP_NETWORK_NAME=dolibarr-mcp-net
MCP_NETWORK_EXTERNAL=false
